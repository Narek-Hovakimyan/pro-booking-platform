{
  "name": "hairbook-backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=18.19.0"
  },
  "scripts": {
    "dev": "NODE_ENV=development nodemon --exec \"node --import ./src/instrument.js\" src/server.js",
    "start": "node --import ./src/instrument.js src/server.js",
    "test": "node --test src/models/User.test.js && node --test --test-concurrency=1 \"src/controllers/**/*.test.js\" \"src/middleware/**/*.test.js\" \"src/models/EventRegistration.test.js\" \"src/models/PlatformAuditLog.test.js\" \"src/routes/**/*.test.js\" \"src/services/**/*.test.js\" \"src/socket.test.js\" \"src/socket.lifecycle.test.js\" \"src/utils/**/*.test.js\"",
    "migrate:salons": "node migrations/migrateToMultipleSalons.js",
    "migrate:fix-work-history": "node migrations/fixWorkHistory.js",
    "migrate:schedule-per-salon": "node migrations/migrateScheduleToPerSalon.js",
    "subscriptions:grace": "node scripts/grantSubscriptionGraceToExistingBarbers.js",
    "audit:legacy-salons": "node scripts/auditLegacySalonFields.js",
    "index:barberprofiles:barberId": "node scripts/createBarberProfileBarberIdUniqueIndex.js"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.9.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.5.0",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^9.0.1",
    "pino": "^10.3.1",
    "resend": "^6.12.3",
    "socket.io": "^4.8.3",
    "@sentry/node": "10.66.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3"
  },
  "overrides": {
    "engine.io": "6.6.8",
    "socket.io-adapter": "2.5.7",
    "ws": "8.20.1",
    "brace-expansion": "5.0.6"
  }
}
