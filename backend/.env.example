# Backend environment configuration
# Copy this file to .env and fill in your values.

NODE_ENV=development              # "development" | "production"
PORT=5000                         # Server port
MONGO_URI=mongodb://127.0.0.1:27017/hairbook  # MongoDB connection string
JWT_SECRET=replace-with-a-long-random-secret   # Use a strong random secret in production
CLIENT_URL=http://localhost:5173               # Frontend origin(s) for CORS (comma-separated)
ENABLE_BOOKING_REMINDERS=false                 # Opt in to smart booking reminder scheduler
BOOKING_REMINDER_INTERVAL_MS=60000             # Scheduler interval when reminders are enabled
ENABLE_WAITLIST_EXPIRATION=false               # Opt in to automatic past-date waitlist expiration
WAITLIST_EXPIRATION_INTERVAL_MS=3600000        # Scheduler interval when waitlist expiration is enabled
ENABLE_CLEANUP_NON_WORKING_DAYS_CRON=false     # Nightly cleanup of past non-working days
ENABLE_EXPIRE_PENDING_BOOKINGS_CRON=false      # Periodically expire past pending bookings
ENABLE_EVENT_REMINDERS_CRON=false              # Send reminders for upcoming events

# Email provider (Resend)
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM="HairBook <no-reply@yourdomain.com>"
EMAIL_REPLY_TO=
APP_PUBLIC_URL=http://localhost:5000
EMAIL_VERIFICATION_LOG_URL=true
