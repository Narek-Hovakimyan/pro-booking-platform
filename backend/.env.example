# Backend environment configuration
# Copy this file to .env and fill in your values for local development or production.
# Never commit .env files — they contain secrets.

NODE_ENV=production              # "development" | "production"
PORT=                            # Server port (e.g. 5000)
TRUST_PROXY=false                # Set true only behind one trusted proxy/load balancer
MONGO_URI=                       # MongoDB connection string (e.g. mongodb+srv://...)
JWT_SECRET=                      # Strong random secret — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CLIENT_URL=                      # Frontend origin(s) for CORS, comma-separated (e.g. https://app.example.com)
APP_PUBLIC_URL=                  # Public URL of this backend (e.g. https://api.example.com)

# Payments — provider-ready, no real provider integrated yet
PAYMENT_PROVIDER=manual           # "manual" | "disabled" | "mock" | "test"; mock/test disabled in production
PAYMENT_WEBHOOK_SECRET=           # Optional provider webhook secret
PAYMENT_SUCCESS_URL=              # Optional checkout success redirect URL
PAYMENT_CANCEL_URL=               # Optional checkout cancel redirect URL

# Email — optional; leave blank if not used
EMAIL_PROVIDER=                  # "resend" or leave empty
RESEND_API_KEY=                  # Resend API key
EMAIL_FROM=                      # Sender address, e.g. "HairBook <noreply@example.com>"
EMAIL_REPLY_TO=                  # Reply-to address (optional)

# Scheduler / cron jobs — all opt-in, false by default
ENABLE_BOOKING_REMINDERS=false               # Smart booking reminder scheduler
BOOKING_REMINDER_INTERVAL_MS=60000
ENABLE_WAITLIST_EXPIRATION=false             # Past-date waitlist expiration
WAITLIST_EXPIRATION_INTERVAL_MS=3600000
ENABLE_SUBSCRIPTION_EXPIRATION_CRON=false    # Periodically expire ended subscriptions
SUBSCRIPTION_EXPIRATION_INTERVAL_MS=86400000
ENABLE_CLEANUP_NON_WORKING_DAYS_CRON=false   # Nightly cleanup of past non-working days
ENABLE_EXPIRE_PENDING_BOOKINGS_CRON=false    # Periodically expire past pending bookings
ENABLE_EVENT_REMINDERS_CRON=false            # Send reminders for upcoming events

# Debug / logging
EMAIL_VERIFICATION_LOG_URL=false             # Log verification links instead of sending email (disable in production)
